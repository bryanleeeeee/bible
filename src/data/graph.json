    { "id": "person:david", "kind": "PERSON", "label": "David", "summary": "Shepherd, psalmist, and Israel's greatest king. His trust in God against Goliath and his psalms shape the Bible's picture of faith." },
    { "id": "person:goliath", "kind": "PERSON", "label": "Goliath", "summary": "The Philistine champion of Gath who defied the armies of Israel in the Valley of Elah." },
    { "id": "person:jesus", "kind": "PERSON", "label": "Jesus", "summary": "The Word made flesh; Son of David and Good Shepherd. Every thread of the graph ultimately converges here." },
    { "id": "person:paul", "kind": "PERSON", "label": "Paul", "summary": "Apostle to the Gentiles; wrote of peace that guards the heart and love that never fails." },
    { "id": "person:joseph", "kind": "PERSON", "label": "Joseph", "summary": "Sold by his brothers, raised to rule Egypt. His story is the Bible's great study in providence and forgiveness." },
    { "id": "person:joshua", "kind": "PERSON", "label": "Joshua", "summary": "Moses' successor, commanded to be strong and courageous because God was with him." },
