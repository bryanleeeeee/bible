# --- Database (optional in dev: app falls back to bundled public-domain data) ---
DATABASE_URL="postgresql://user:password@localhost:5432/lumen"
DIRECT_URL="postgresql://user:password@localhost:5432/lumen"

# --- Auth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- AI assistant + semantic search (optional; grounded local fallback used if absent) ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
EMBEDDINGS_PROVIDER="openai"   # openai | local | none

# --- Licensed Bible text providers (optional) ---
# The app ships with public-domain KJV/WEB. NIV/NLT/NKJV/MSG require licensed APIs.
APIBIBLE_KEY=""                # https://scripture.api.bible
BIBLIA_KEY=""                  # https://bibliaapi.com

# --- Caching (optional) ---
REDIS_URL=""
